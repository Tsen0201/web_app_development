# 任務管理系統 — 環境變數範例
# 複製此檔案為 .env 並填入實際值

# Flask SECRET_KEY（用於 session 與 flash message）
# 正式環境請使用隨機字串，例如：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production

# Flask 環境設定（development / production）
FLASK_ENV=development

# Flask Debug 模式（1=開啟, 0=關閉）
FLASK_DEBUG=1
